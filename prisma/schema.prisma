generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  interviews Interview[]
  feedbacks  Feedback[]
  challengeSubmissions ChallengeSubmission[]
  challengeStars      ChallengeStar[]

  @@map("users")
}

model Interview {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  role       String
  level      String
  type       String
  techstack  String[]
  questions  String[]
  language   String   @default("en")
  finalized  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  transcripts Transcript[]
  feedback    Feedback?

  @@map("interviews")
}

model Transcript {
  id          String   @id @default(uuid())
  interviewId String   @map("interview_id")
  role        String   // "user" | "assistant"
  content     String
  sequence    Int
  createdAt   DateTime @default(now()) @map("created_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("transcripts")
}

model Feedback {
  id                  String   @id @default(uuid())
  interviewId         String   @unique @map("interview_id")
  userId              String   @map("user_id")
  totalScore          Int      @map("total_score")
  strengths           String[]
  areasForImprovement String[] @map("areas_for_improvement")
  finalAssessment     String   @map("final_assessment")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  interview      Interview       @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id])
  categoryScores CategoryScore[]

  @@map("feedbacks")
}

model CategoryScore {
  id         String @id @default(uuid())
  feedbackId String @map("feedback_id")
  name       String
  score      Int
  comment    String

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@map("category_scores")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Skill {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  icon        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  challenges Challenge[]

  @@map("skills")
}

model Challenge {
  id           String     @id @default(uuid())
  skillId      String     @map("skill_id")
  title        String
  slug         String     @unique
  description  String     @db.Text
  difficulty   Difficulty @default(EASY)
  subdomain    String     @default("")
  skillLevel   String     @default("Basic") @map("skill_level")
  templateCode Json       @map("template_code")
  testCases    Json       @map("test_cases")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  skill       Skill                 @relation(fields: [skillId], references: [id])
  submissions ChallengeSubmission[]
  stars       ChallengeStar[]

  @@map("challenges")
}

model ChallengeSubmission {
  id           String   @id @default(uuid())
  challengeId  String   @map("challenge_id")
  userId       String   @map("user_id")
  code         String   @db.Text
  language     String
  status       String   @default("PENDING")
  runtime      Int?
  memory       Int?
  errorMessage String?  @map("error_message") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  challenge Challenge @relation(fields: [challengeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("challenge_submissions")
}
model ChallengeStar {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  challengeId String   @map("challenge_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id])
  challenge Challenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
  @@map("challenge_stars")
}
